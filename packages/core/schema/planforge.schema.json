{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanForge Config",
  "type": "object",
  "properties": {
    "planner": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["claude"], "default": "claude" },
        "model": { "type": "string", "default": "opus" },
        "effort": { "type": "string", "enum": ["low", "medium", "high"], "default": "high" }
      },
      "default": { "provider": "claude", "model": "opus", "effort": "high" }
    },
    "implementer": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["codex"], "default": "codex" },
        "model": { "type": "string", "default": "codex" }
      },
      "default": { "provider": "codex", "model": "codex" }
    },
    "plansDir": { "type": "string", "default": ".cursor/plans" }
  }
}
