{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PlanForge Config",
  "type": "object",
  "properties": {
    "planner": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["claude", "codex"] },
        "model": { "type": "string" },
        "effort": { "type": "string", "enum": ["low", "medium", "high"] },
        "reasoning": { "type": "string", "enum": ["low", "high"] }
      }
    },
    "implementer": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["claude", "codex"] },
        "model": { "type": "string" },
        "effort": { "type": "string", "enum": ["low", "medium", "high"] },
        "reasoning": { "type": "string", "enum": ["low", "high"] }
      }
    },
    "plansDir": { "type": "string", "default": ".cursor/plans" }
  }
}
