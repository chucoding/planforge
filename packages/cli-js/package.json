{
  "name": "planforge",
  "version": "0.1.4",
  "type": "module",
  "description": "PlanForge CLI - Bring your own AI to Cursor",
  "keywords": ["cursor", "claude", "codex", "ai", "cli", "planning", "planforge"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chucoding/planforge.git"
  },
  "bugs": "https://github.com/chucoding/planforge/issues",
  "homepage": "https://github.com/chucoding/planforge#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md"],
  "bin": {
    "planforge": "dist/index.js"
  },
  "scripts": {
    "check:templates": "node scripts/check-templates.js",
    "build": "pnpm run check:templates && tsc",
    "dev": "tsc --watch",
    "planforge": "node dist/index.js",
    "install:global": "pnpm run build && npm install -g .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@daun_jung/korean-romanizer": "^1.0.1",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}